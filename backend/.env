NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:5173
JWT_SECRET=replace-me
SESSION_SECRET=replace-me
MONGODB_URI=mongodb://localhost:27017/video_caption
ADMIN_EMAIL=cmsadanasree@gmail.com

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# Google Cloud
GOOGLE_PROJECT_ID=
# If using a service account JSON file, set:
# GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service-account.json

# Captioning options
DEFAULT_SOURCE_LANG=en-US
# Local transcription / translation (no cloud required)
LOCAL_TRANSCRIBE=1
LOCAL_TRANSLATE=1
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_BEAM_SIZE=1
WHISPER_BEST_OF=1
WHISPER_VAD_FILTER=0
PUBLIC_TRANSLATE_CONCURRENCY=10
PYTHON_PATH=C:\Users\cmsad\AppData\Local\Programs\Python\Python314\python.exe
YTDLP_PATH=C:\video caption\.venv\Scripts\yt-dlp.exe
# Optional: if Instagram requires login, export browser cookies and set a path:
# YTDLP_COOKIES=C:\path\to\cookies.txt
# Optional: if your network needs a proxy:
# YTDLP_PROXY=http://user:pass@host:port
